#!/usr/bin/env bash
set -euo pipefail

run_ps1_cross() {
  local script="$1"
  shift || true
  if command -v pwsh >/dev/null 2>&1; then
    pwsh -NoProfile -ExecutionPolicy Bypass -File "${script}" "$@"
    return $?
  fi
  if command -v powershell.exe >/dev/null 2>&1; then
    local script_win="${script}"
    if command -v wslpath >/dev/null 2>&1; then
      script_win="$(wslpath -w "${script}")"
    fi
    powershell.exe -NoProfile -ExecutionPolicy Bypass -File "${script_win}" "$@"
    return $?
  fi
  echo "[rayman] neither pwsh nor powershell.exe found for ${script}" >&2
  return 2
}

rayman_bool_enabled() {
  local raw="${1:-}"
  local default_value="${2:-0}"
  if [[ -z "${raw}" ]]; then
    [[ "${default_value}" == "1" ]]
    return $?
  fi
  case "${raw,,}" in
    1|true|yes|y|on) return 0 ;;
    0|false|no|n|off) return 1 ;;
    *) [[ "${default_value}" == "1" ]] ;;
  esac
}

rayman_should_emit_done_alert() {
  local command_name="${1:-}"
  shift || true

  case "${command_name}" in
    ""|help|-h|--help|copy-self-check|codex) return 1 ;;
  esac

  if rayman_bool_enabled "${CI:-}" 0; then
    return 1
  fi

  if [[ ! -t 1 && ! -t 2 ]]; then
    return 1
  fi

  local token=""
  for token in "$@"; do
    [[ -z "${token}" ]] && continue
    token="${token#--}"
    token="${token#-}"
    case "${token,,}" in
      json|as-json|asjson) return 1 ;;
    esac
  done

  if ! rayman_bool_enabled "${RAYMAN_ALERTS_ENABLED:-}" 1; then
    return 1
  fi

  if ! rayman_bool_enabled "${RAYMAN_ALERT_DONE_ENABLED:-}" 1; then
    return 1
  fi

  return 0
}

rayman_emit_done_alert() {
  local command_name="${1:-}"
  shift || true

  if ! rayman_should_emit_done_alert "${command_name}" "$@"; then
    return 0
  fi

  local title="Rayman 完成提醒"
  local message="Rayman 命令已完成：${command_name}"
  local root
  root="$(pwd)"
  local alert_script="${root}/.Rayman/scripts/utils/request_attention.ps1"

  if [[ -f "${alert_script}" ]]; then
    if command -v pwsh >/dev/null 2>&1; then
      pwsh -NoProfile -ExecutionPolicy Bypass -File "${alert_script}" -Kind done -Title "${title}" -Message "${message}" -WorkspaceRoot "${root}" >/dev/null 2>&1 || true
      return 0
    fi
    if command -v powershell.exe >/dev/null 2>&1; then
      local alert_script_win="${alert_script}"
      local root_win="${root}"
      if command -v wslpath >/dev/null 2>&1; then
        alert_script_win="$(wslpath -w "${alert_script}")"
        root_win="$(wslpath -w "${root}")"
      fi
      powershell.exe -NoProfile -ExecutionPolicy Bypass -File "${alert_script_win}" -Kind done -Title "${title}" -Message "${message}" -WorkspaceRoot "${root_win}" >/dev/null 2>&1 || true
      return 0
    fi
  fi

  if command -v notify-send >/dev/null 2>&1; then
    notify-send "${title}" "${message}" >/dev/null 2>&1 || true
  fi

  if rayman_bool_enabled "${RAYMAN_ALERT_TTS_ENABLED:-}" 1 && rayman_bool_enabled "${RAYMAN_ALERT_TTS_DONE_ENABLED:-}" 1; then
    if command -v spd-say >/dev/null 2>&1; then
      spd-say "${message}" >/dev/null 2>&1 || true
    fi
  fi
}

cmd="${1:-help}"
shift || true
orig_cmd="${cmd}"
orig_args=("$@")

rayman_show_help() {
  local catalog="./.Rayman/config/command_catalog.tsv"
  cat <<'TXT'
Rayman CLI (v165)

Usage:
  ./.Rayman/rayman <command>

Platform tags:
  [all]          Publicly supported from both bash `rayman` and PowerShell `rayman.ps1`.
  [pwsh-only]    Use `rayman.ps1 <command>`.
  [windows-only] Use `rayman.ps1 <command>` on a Windows host.

Commands:
TXT

  if [[ ! -f "${catalog}" ]]; then
    echo "  (command catalog missing: ${catalog})"
    return 2
  fi

  while IFS=$'\t' read -r name platform group summary recommended; do
    [[ -z "${name}" ]] && continue
    [[ "${name}" == \#* ]] && continue
    [[ "${platform}" != "all" ]] && continue
    printf '  %-18s [%s] %s\n' "${name}" "${platform}" "${summary}"
  done < "${catalog}"

  cat <<'TXT'

Notes:
  - This bash entry publicly supports only commands tagged `[all]`.
  - For `[pwsh-only]` or `[windows-only]` commands, use `rayman.ps1 <command>`.
TXT
}

case "$cmd" in
  help|-h|--help)
    rayman_show_help
    ;;

  init)
    bash ./.Rayman/init.sh "$@"
    ;;

  watch)
    bash ./.Rayman/run/watch.sh "$@"
    ;;

  fast-init)
    bash ./.Rayman/scripts/fast-init/fast-init.sh "$@"
    ;;

  migrate)
    bash ./.Rayman/scripts/requirements/migrate_legacy_requirements.sh "$@"
    ;;

  doctor)
    copy_smoke=0
    smoke_strict=0
    smoke_keep_temp=0
    smoke_timeout="120"
    smoke_scope="wsl"
    forward=()
    while (($#)); do
      case "$1" in
        --copy-smoke) copy_smoke=1 ;;
        --strict) smoke_strict=1 ;;
        --keep-temp) smoke_keep_temp=1 ;;
        --scope)
          shift || { echo "missing value for --scope" >&2; exit 2; }
          smoke_scope="${1:-wsl}"
          ;;
        --timeout-seconds)
          shift || { echo "missing value for --timeout-seconds" >&2; exit 2; }
          smoke_timeout="${1:-120}"
          ;;
        *) forward+=("$1") ;;
      esac
      shift || true
    done

    if [[ "${copy_smoke}" == "1" ]]; then
      root="$(pwd)"
      script_ps1="${root}/.Rayman/scripts/release/copy_smoke.ps1"
      [[ -f "${script_ps1}" ]] || { echo "[copy-smoke] missing script: ${script_ps1}" >&2; exit 2; }

      if command -v pwsh >/dev/null 2>&1; then
        args=(-NoProfile -ExecutionPolicy Bypass -File "${script_ps1}" -WorkspaceRoot "${root}" -TimeoutSeconds "${smoke_timeout}" -Scope "${smoke_scope}")
        [[ "${smoke_strict}" == "1" ]] && args+=(-Strict)
        [[ "${smoke_keep_temp}" == "1" ]] && args+=(-KeepTemp)
        pwsh "${args[@]}"
      elif command -v powershell.exe >/dev/null 2>&1; then
        if command -v wslpath >/dev/null 2>&1; then
          script_ps1="$(wslpath -w "${script_ps1}")"
          root="$(wslpath -w "${root}")"
        fi
        args=(-NoProfile -ExecutionPolicy Bypass -File "${script_ps1}" -WorkspaceRoot "${root}" -TimeoutSeconds "${smoke_timeout}" -Scope "${smoke_scope}")
        [[ "${smoke_strict}" == "1" ]] && args+=(-Strict)
        [[ "${smoke_keep_temp}" == "1" ]] && args+=(-KeepTemp)
        powershell.exe "${args[@]}"
      else
        echo "[copy-smoke] neither pwsh nor powershell.exe found" >&2
        exit 2
      fi
    else
      bash ./.Rayman/run/rules.sh doctor "${forward[@]}"
    fi
    ;;

  copy-self-check)
    exec bash "$0" doctor --copy-smoke "$@"
    ;;

  check)
    bash ./.Rayman/run/check.sh
    ;;

  fast-gate)
    run_ps1_cross "./.Rayman/scripts/project/run_project_gate.ps1" -WorkspaceRoot "$(pwd)" -Lane fast "$@"
    ;;

  browser-gate)
    run_ps1_cross "./.Rayman/scripts/project/run_project_gate.ps1" -WorkspaceRoot "$(pwd)" -Lane browser "$@"
    ;;

  full-gate)
    run_ps1_cross "./.Rayman/scripts/project/run_project_gate.ps1" -WorkspaceRoot "$(pwd)" -Lane full "$@"
    ;;

  ensure-test-deps)
    bash ./.Rayman/scripts/utils/ensure_project_test_deps.sh "$@"
    ;;

  ensure-playwright)
    bash ./.Rayman/scripts/pwa/ensure_playwright_wsl.sh "$@"
    ;;

  ensure-winapp)
    run_ps1_cross "./.Rayman/scripts/windows/ensure_winapp.ps1" -WorkspaceRoot "$(pwd)" "$@"
    ;;

  winapp-test)
    run_ps1_cross "./.Rayman/scripts/windows/run_winapp_flow.ps1" -WorkspaceRoot "$(pwd)" "$@"
    ;;

  winapp-inspect)
    run_ps1_cross "./.Rayman/scripts/windows/inspect_winapp.ps1" -WorkspaceRoot "$(pwd)" "$@"
    ;;

  clean)
    bash ./.Rayman/scripts/utils/clean_workspace.sh "$@"
    ;;

  snapshot)
    bash ./.Rayman/scripts/backup/snapshot_workspace.sh "$@"
    ;;

  metrics)
    bash ./.Rayman/scripts/telemetry/rules_metrics.sh "$@"
    ;;

  trend)
    bash ./.Rayman/scripts/telemetry/daily_trend.sh "$@"
    ;;

  baseline-guard)
    bash ./.Rayman/scripts/telemetry/baseline_guard.sh "$@"
    ;;

  telemetry-export)
    bash ./.Rayman/scripts/telemetry/export_artifacts.sh "$@"
    ;;

  telemetry-index)
    bash ./.Rayman/scripts/telemetry/index_artifacts.sh "$@"
    ;;

  telemetry-prune)
    bash ./.Rayman/scripts/telemetry/prune_artifacts.sh "$@"
    ;;

  dispatch)
    run_ps1_cross "./.Rayman/scripts/agents/dispatch.ps1" -WorkspaceRoot "$(pwd)" "$@"
    ;;

  review-loop)
    run_ps1_cross "./.Rayman/scripts/agents/review_loop.ps1" -WorkspaceRoot "$(pwd)" "$@"
    ;;

  first-pass-report)
    run_ps1_cross "./.Rayman/scripts/agents/first_pass_report.ps1" -WorkspaceRoot "$(pwd)" "$@"
    ;;

  prompts)
    run_ps1_cross "./.Rayman/scripts/agents/prompts_catalog.ps1" -WorkspaceRoot "$(pwd)" "$@"
    ;;

  agent-capabilities)
    run_ps1_cross "./.Rayman/scripts/agents/ensure_agent_capabilities.ps1" -WorkspaceRoot "$(pwd)" "$@"
    ;;

  codex)
    run_ps1_cross "./.Rayman/scripts/codex/manage_accounts.ps1" -WorkspaceRoot "$(pwd)" "$@"
    ;;

  transfer-export)
    run_ps1_cross "./.Rayman/rayman.ps1" transfer-export "$@"
    ;;

  transfer-import)
    run_ps1_cross "./.Rayman/rayman.ps1" transfer-import "$@"
    ;;

  release)
    bash ./.Rayman/run/rules.sh release
    ;;

  dev)
    bash ./.Rayman/run/rules.sh dev
    ;;

  *)
    echo "Unknown command: $cmd" >&2
    exit 2
    ;;
esac

rayman_emit_done_alert "${orig_cmd}" "${orig_args[@]}"
