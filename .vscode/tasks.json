{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Rayman: Auto Start Watchers",
			"type": "shell",
			"command": "powershell",
			"args": [
				"-NoProfile",
				"-ExecutionPolicy",
				"Bypass",
				"-Command",
				"Write-Host '⚠️ [Rayman task] Rayman: Auto Start Watchers 已降级为 no-op（host, missing: .Rayman/scripts/watch/start_background_watchers.ps1, .Rayman/common.ps1）' -ForegroundColor Yellow; exit 0"
			],
			"linux": {
				"command": "bash",
				"args": [
					"-lc",
					"echo \"⚠️ [Rayman task] Rayman: Auto Start Watchers 已降级为 no-op（linux, missing: .Rayman/scripts/watch/start_background_watchers.ps1, .Rayman/common.ps1）\"; exit 0"
				]
			},
			"runOptions": {
				"runOn": "folderOpen"
			},
			"presentation": {
				"reveal": "never",
				"panel": "shared",
				"clear": false
			},
			"problemMatcher": []
		},
		{
			"label": "Rayman: Check Win Deps",
			"type": "shell",
			"command": "powershell",
			"args": [
				"-NoProfile",
				"-ExecutionPolicy",
				"Bypass",
				"-Command",
				"Write-Host '⚠️ [Rayman task] Rayman: Check Win Deps 已降级为 no-op（host, missing: .Rayman/scripts/utils/check_win_deps.ps1）' -ForegroundColor Yellow; exit 0"
			],
			"linux": {
				"command": "bash",
				"args": [
					"-lc",
					"echo \"⚠️ [Rayman task] Rayman: Check Win Deps 已降级为 no-op（linux, missing: .Rayman/scripts/utils/check_win_deps.ps1）\"; exit 0"
				]
			},
			"runOptions": {
				"runOn": "folderOpen"
			},
			"presentation": {
				"reveal": "never",
				"panel": "shared",
				"clear": false
			},
			"problemMatcher": []
		},
		{
			"label": "Rayman: Test & Fix",
			"type": "shell",
			"command": "powershell",
			"linux": {
				"command": "pwsh"
			},
			"args": [
				"-NoProfile",
				"-ExecutionPolicy",
				"Bypass",
				"-File",
				"${workspaceFolder}/.Rayman/scripts/repair/run_tests_and_fix.ps1"
			],
			"presentation": {
				"reveal": "always",
				"panel": "shared",
				"clear": false
			},
			"problemMatcher": []
		},
		{
			"label": "Rayman: Release Gate",
			"type": "shell",
			"command": "powershell",
			"linux": {
				"command": "pwsh"
			},
			"args": [
				"-NoProfile",
				"-ExecutionPolicy",
				"Bypass",
				"-File",
				"${workspaceFolder}/.Rayman/scripts/release/release_gate.ps1",
				"-WorkspaceRoot",
				"${workspaceFolder}"
			],
			"presentation": {
				"reveal": "always",
				"panel": "shared",
				"clear": false
			},
			"problemMatcher": []
		}
	]
}
