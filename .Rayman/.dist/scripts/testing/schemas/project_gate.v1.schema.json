{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Rayman project gate report v1",
  "type": "object",
  "required": [
    "schema",
    "generated_at",
    "workspace_root",
    "lane",
    "overall",
    "success",
    "counts",
    "checks"
  ],
  "properties": {
    "schema": {
      "const": "rayman.project_gate.v1"
    },
    "generated_at": {
      "type": "string"
    },
    "workspace_root": {
      "type": "string",
      "minLength": 1
    },
    "lane": {
      "type": "string",
      "enum": [
        "fast",
        "browser",
        "full"
      ]
    },
    "config_path": {
      "type": "string"
    },
    "config_exists": {
      "type": "boolean"
    },
    "overall": {
      "type": "string",
      "enum": [
        "PASS",
        "WARN",
        "FAIL"
      ]
    },
    "success": {
      "type": "boolean"
    },
    "counts": {
      "type": "object",
      "required": [
        "pass",
        "warn",
        "fail",
        "skip",
        "total"
      ],
      "properties": {
        "pass": { "type": "integer", "minimum": 0 },
        "warn": { "type": "integer", "minimum": 0 },
        "fail": { "type": "integer", "minimum": 0 },
        "skip": { "type": "integer", "minimum": 0 },
        "total": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": false
    },
    "checks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "key",
          "name",
          "status",
          "detail",
          "action",
          "command",
          "log_path",
          "exit_code",
          "duration_seconds"
        ],
        "properties": {
          "key": { "type": "string", "minLength": 1 },
          "name": { "type": "string", "minLength": 1 },
          "status": {
            "type": "string",
            "enum": [
              "PASS",
              "WARN",
              "FAIL",
              "SKIP"
            ]
          },
          "detail": { "type": "string" },
          "action": { "type": "string" },
          "command": { "type": "string" },
          "log_path": { "type": "string" },
          "exit_code": { "type": "integer" },
          "duration_seconds": { "type": "number", "minimum": 0 }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
