{
  "git.untrackedChanges": "separate",
  "editor.largeFileOptimizations": true,
  "files.watcherExclude": {
    "**/node_modules/*/**": true,
    "**/.git/objects/**": true,
    "**/.playwright-mcp/**": true,
    "**/.rag/**": true,
    "**/gtp_logs/**": true,
    "**/bin/**": true,
    "**/.artifacts/**": true,
    "**/obj/**": true
  },
  "search.exclude": {
    "**/gtp_logs": true,
    "**/bin": true,
    "**/.artifacts": true,
    "**/node_modules": true,
    "**/obj": true,
    "**/.rag": true
  }
}
